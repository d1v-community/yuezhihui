# Remix + Neon + Drizzle

# Required - Neon PostgreSQL Database
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require"

# App Configuration
APP_URL="http://localhost:5173"
LOG_LEVEL="info"
NODE_ENV="development"

# Resend Email Service (optional - will log codes to console if not set)
# Get your API key from: https://resend.com
RESEND_API_KEY=your_resend_api_key

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# WeChat Configuration (optional - required for WeChat login)
# Get these from: https://developers.weixin.qq.com/miniprogram/dev/devtools/download.html
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# WeChat Pay Configuration (optional - required for payments)
# Get these from WeChat Pay Merchant Platform: https://pay.weixin.qq.com/
# - MCHID: Merchant ID
# - SERIAL_NO: API Certificate serial number
# - API_V3_KEY: API v3 key (32 characters)
WECHAT_PAY_MCHID=your_merchant_id
WECHAT_PAY_SERIAL_NO=your_certificate_serial_number
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_PRIVATE_KEY_PATH="certs/apiclient_key.pem"
WECHAT_PAY_NOTIFY_URL="https://your-domain.com/api/pay/wechat/notify"
