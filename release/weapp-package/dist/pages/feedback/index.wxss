.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:18rpx 16rpx 22rpx;width:100%}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.headerRow{align-items:center;display:flex;gap:10rpx}.backBtn{align-items:center;background:hsla(0,0%,100%,.86);border:1rpx solid rgba(0,0,0,.08);border-radius:12rpx;display:flex;height:32rpx;justify-content:center;width:32rpx}.backIcon{color:rgba(0,0,0,.72);font-size:16rpx;line-height:16rpx}.title{display:block;font-size:18rpx;font-weight:800;letter-spacing:-.2rpx}.desc{color:rgba(0,0,0,.55);display:block;font-size:12rpx;line-height:18rpx;margin-top:6rpx}.section{margin-top:16rpx}.sectionTitle{color:rgba(0,0,0,.78);display:block;font-size:13rpx;font-weight:800}.muted{color:rgba(0,0,0,.55);display:block;font-size:12rpx;line-height:18rpx;margin-top:8rpx}.options{display:flex;flex-direction:column;gap:10rpx;margin-top:10rpx}.textarea{background:#fff;border:1rpx solid rgba(0,0,0,.12);border-radius:12rpx;box-sizing:border-box;color:rgba(0,0,0,.92);font-size:16rpx;height:120rpx;line-height:22rpx;line-height:20rpx;margin-top:10rpx;padding:10rpx 12rpx;width:100%}.textarea::placeholder{color:rgba(0,0,0,.35)}.textarea:focus{border-color:rgba(0,0,0,.28)}