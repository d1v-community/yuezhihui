.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:26rpx 16rpx 22rpx;width:100%}.brandRow{align-items:center;display:flex;justify-content:space-between;margin-bottom:18rpx}.brandMark{align-items:center;background:rgba(43,43,43,.94);border-radius:12rpx;display:flex;height:36rpx;justify-content:center;width:36rpx}.brandMarkText{color:#fff;font-size:12rpx;font-weight:700;letter-spacing:.2rpx}.heroTitle{color:rgba(0,0,0,.92);display:block;font-size:26rpx;font-weight:800;letter-spacing:-.4rpx}.heroDesc{color:rgba(0,0,0,.58);display:block;font-size:14rpx;line-height:20rpx;margin-top:8rpx}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;margin-top:16rpx;padding:16rpx}.field{margin-top:14rpx}.label{color:rgba(0,0,0,.7);font-size:13rpx;margin-bottom:8rpx}.input{background:#fff;border:1rpx solid rgba(0,0,0,.12);border-radius:12rpx;box-sizing:border-box;color:rgba(0,0,0,.92);font-size:16rpx;line-height:22rpx;padding:12rpx;width:100%}.input::placeholder{color:rgba(0,0,0,.35)}.input:focus{border-color:rgba(0,0,0,.28)}.helperRow{align-items:center;display:flex;gap:10rpx;justify-content:space-between;margin-top:12rpx}.keypad{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:14rpx}.keypadTitle{color:rgba(0,0,0,.62);display:block;font-size:12rpx;font-weight:700;letter-spacing:.08em;margin-top:14rpx;text-transform:uppercase}.keypadCell{width:calc(33.33333% - 20rpx/3)}.keypadActionIcon{font-size:18rpx;font-weight:700;line-height:1}.helperText{color:rgba(0,0,0,.55);font-size:12rpx}.actions{display:flex;flex-direction:column;gap:10rpx;margin-top:16rpx}.devCallout{align-items:center;background:hsla(28,24%,72%,.18);border:1rpx solid rgba(139,94,94,.14);border-radius:12rpx;display:flex;gap:12rpx;justify-content:space-between;margin-top:12rpx;padding:10rpx 12rpx}.devCode{color:rgba(0,0,0,.86);font-size:14rpx;font-weight:700;letter-spacing:2rpx}.devHint{color:rgba(0,0,0,.55);font-size:12rpx}.footNote{color:rgba(0,0,0,.5);font-size:12rpx;line-height:18rpx;margin-top:14rpx}