.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:18rpx 16rpx 22rpx;width:100%}.wrapSummary{padding-top:12rpx}.topbar{backdrop-filter:blur(10rpx);background:hsla(40,27%,98%,.55);border-bottom:1rpx solid rgba(0,0,0,.05);margin-bottom:10rpx;margin-left:-16rpx;margin-right:-16rpx;padding:8rpx 16rpx 10rpx;position:sticky;top:0;z-index:10}.topbarCompact{margin-bottom:6rpx;padding-bottom:6rpx;padding-top:4rpx}.topbarCompact .progressRow{margin-top:4rpx}.topbarCompact .progressText{line-height:16rpx}.topbarCompact .topTitle{font-size:16rpx;line-height:20rpx}.topTitle{font-size:18rpx;font-weight:700;letter-spacing:-.2rpx}.progressRow{align-items:center;display:flex;gap:10rpx;justify-content:space-between;margin-top:8rpx}.progressText{color:rgba(0,0,0,.55);font-size:12rpx}.bar{background:rgba(0,0,0,.05);border-radius:999rpx;height:8rpx;margin-top:10rpx;overflow:hidden}.barFill{background:rgba(43,43,43,.88);border-radius:999rpx;height:8rpx}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.chipsRow{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:12rpx}.chip{align-items:center;background:rgba(0,0,0,.04);border:1rpx solid rgba(0,0,0,.08);border-radius:999rpx;color:rgba(0,0,0,.7);display:inline-flex;font-size:12rpx;padding:6rpx 10rpx}.chipActive{background:hsla(28,24%,72%,.25);border-color:rgba(139,94,94,.28);color:rgba(0,0,0,.86)}.searchRow{margin-top:12rpx}.searchInput{background:#fff;border:1rpx solid rgba(0,0,0,.12);border-radius:12rpx;box-sizing:border-box;color:rgba(0,0,0,.92);font-size:16rpx;line-height:22rpx;padding:12rpx;width:100%}.searchInput::placeholder{color:rgba(0,0,0,.35)}.searchInput:focus{border-color:rgba(0,0,0,.28)}.grid{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:12rpx}.gridItem{background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.1);border-radius:999rpx;color:rgba(0,0,0,.78);font-size:12rpx;line-height:18rpx;max-width:100%;padding:8rpx 10rpx}.gridItemActive{background:hsla(28,24%,72%,.22);border-color:rgba(139,94,94,.28);color:rgba(0,0,0,.86)}.summaryList{display:flex;flex-direction:column;gap:8rpx;margin-top:12rpx}.summaryItem{background:hsla(0,0%,100%,.9);border:1rpx solid rgba(0,0,0,.08);border-radius:12rpx;padding:10rpx 12rpx}.summaryHead{align-items:center;display:flex;gap:10rpx;justify-content:space-between}.summaryKey{color:rgba(0,0,0,.5);font-size:12rpx}.summaryVal{color:rgba(0,0,0,.86);display:block;font-size:14rpx;line-height:18rpx;margin-top:4rpx}.summaryEditIcon{align-items:center;background:hsla(0,0%,100%,.86);border:1rpx solid rgba(0,0,0,.1);border-radius:12rpx;display:flex;flex:0 0 auto;height:36rpx;justify-content:center;width:40rpx}.summaryEditIconText{color:rgba(0,0,0,.7);font-size:14rpx;line-height:14rpx}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.title{display:block;font-size:18rpx;font-weight:700;line-height:24rpx}.note{color:rgba(0,0,0,.55);display:block;font-size:12rpx;line-height:18rpx;margin-top:8rpx}.options{display:flex;flex-direction:column;gap:10rpx;margin-top:14rpx}.opt{background:hsla(0,0%,100%,.9);border:1rpx solid rgba(0,0,0,.1);border-radius:14rpx;padding:12rpx}.optActive{background:hsla(28,24%,72%,.18);border-color:rgba(139,94,94,.3)}.optRow{align-items:flex-start;display:flex;gap:10rpx;justify-content:space-between}.optLabel{flex:1;font-size:14rpx;line-height:20rpx}.optMark{align-items:center;background:hsla(0,0%,100%,.95);border:1rpx solid rgba(0,0,0,.12);border-radius:999rpx;display:flex;height:20rpx;justify-content:center;width:20rpx}.optMarkActive{background:rgba(139,94,94,.12);border-color:rgba(139,94,94,.35)}.optMarkText{color:rgba(0,0,0,.68);font-size:12rpx;font-weight:700}.field{margin-top:14rpx}.input{background:#fff;border:1rpx solid rgba(0,0,0,.12);border-radius:12rpx;box-sizing:border-box;color:rgba(0,0,0,.92);font-size:16rpx;line-height:22rpx;padding:12rpx;width:100%}.input::placeholder{color:rgba(0,0,0,.35)}.input:focus{border-color:rgba(0,0,0,.28)}.metaRow{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:10rpx}.metaBtn{align-items:center;background:rgba(0,0,0,.04);border:1rpx solid rgba(0,0,0,.08);border-radius:999rpx;color:rgba(0,0,0,.7);display:inline-flex;font-size:12rpx;padding:6rpx 10rpx}.metaBtnActive{background:hsla(28,24%,72%,.25);border-color:rgba(139,94,94,.28);color:rgba(0,0,0,.86)}.finishTitle{font-size:20rpx;font-weight:700}.finishDesc{color:rgba(0,0,0,.55);font-size:14rpx;line-height:20rpx;margin-top:8rpx}.actionsBar{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border-top:1rpx solid rgba(0,0,0,.06);bottom:0;left:0;padding:12rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));position:fixed;right:0}.actionsSpacer{height:92rpx}.actionsRow{display:flex;gap:10rpx}