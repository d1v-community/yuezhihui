.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:30rpx 16rpx 22rpx;width:100%}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.brand{align-items:center;display:flex;gap:10rpx;margin-bottom:16rpx}.mark{align-items:center;background:rgba(43,43,43,.94);border-radius:12rpx;display:flex;height:34rpx;justify-content:center;width:34rpx}.markText{color:#fff;font-size:12rpx;font-weight:700}.title{font-size:18rpx;font-weight:800;letter-spacing:-.2rpx}.desc{color:rgba(0,0,0,.56);font-size:14rpx;line-height:20rpx;margin-top:8rpx}.actions{display:flex;flex-direction:column;gap:10rpx;margin-top:14rpx}