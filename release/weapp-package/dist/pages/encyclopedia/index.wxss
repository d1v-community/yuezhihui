.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:18rpx 16rpx 22rpx;width:100%}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.row{align-items:center;display:flex;gap:12rpx;justify-content:space-between}.title{font-size:18rpx;font-weight:800;letter-spacing:-.2rpx}.desc{color:rgba(0,0,0,.62);display:block;font-size:13rpx;line-height:18rpx;margin-top:10rpx}.section{margin-top:14rpx}.slogan-section{background:linear-gradient(135deg,rgba(139,94,94,.08),hsla(28,24%,72%,.12));border:1rpx solid rgba(139,94,94,.12);border-radius:16rpx;margin-top:20rpx;padding:20rpx 16rpx}.slogan-title{color:rgba(0,0,0,.86);display:block;font-size:18rpx;font-weight:900;letter-spacing:-.2rpx;text-align:center}.slogan-desc{color:rgba(0,0,0,.62);display:block;font-size:13rpx;line-height:20rpx;margin-top:10rpx;text-align:center}.faq-section{margin-top:24rpx}.faq-title{color:rgba(0,0,0,.78);display:block;font-size:14rpx;font-weight:900;letter-spacing:-.2rpx}.faq-list{display:flex;flex-direction:column;gap:10rpx;margin-top:12rpx;overflow-x:auto;padding-bottom:8rpx}.faq-card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);background:hsla(0,0%,100%,.8);border:1rpx solid rgba(139,94,94,.1);border-radius:16rpx;padding:14rpx 16rpx}.faq-question{color:rgba(0,0,0,.86);display:block;font-size:14rpx;font-weight:900;letter-spacing:-.2rpx}.faq-desc{color:rgba(0,0,0,.62);display:block;font-size:12rpx;line-height:18rpx;margin-top:8rpx}.faq-more{display:flex;justify-content:center;margin-top:16rpx}.wiki-container{background:#fff;bottom:0;display:flex;flex-direction:column;left:0;position:fixed;right:0;top:0;z-index:1000}.wiki-header{background:#fff;border-bottom:1rpx solid rgba(0,0,0,.1);padding:8rpx 16rpx}.sectionTitle{color:rgba(0,0,0,.78);display:block;font-size:13rpx;font-weight:900;letter-spacing:-.2rpx;margin-top:6rpx}.cardList{display:flex;flex-direction:column;gap:10rpx;margin-top:10rpx}.kbCard{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:14rpx}.kbCardOpen{border-color:rgba(139,94,94,.18);box-shadow:0 12rpx 40rpx rgba(43,43,43,.06)}.kbHead{align-items:baseline;display:flex;gap:8rpx}.kbTag{background:hsla(28,24%,72%,.18);border:1rpx solid rgba(139,94,94,.16);border-radius:999rpx;color:rgba(0,0,0,.72);flex:none;font-size:11rpx;font-weight:800;padding:2rpx 8rpx}.kbTitle{color:rgba(0,0,0,.86);flex:1;font-size:14rpx;font-weight:900;min-width:0}.kbMore{color:rgba(0,0,0,.46);flex:none;font-size:11rpx}.kbLead{color:rgba(0,0,0,.62);display:block;font-size:12rpx;line-height:18rpx;margin-top:8rpx}.kbBody{margin-top:10rpx}.kbP{color:rgba(0,0,0,.72);display:block;font-size:12rpx;line-height:18rpx;margin-top:8rpx}.kbBlock{margin-top:10rpx}.kbSub{color:rgba(0,0,0,.76);display:block;font-size:12rpx;font-weight:900}.kbLi{color:rgba(0,0,0,.68);display:block;font-size:12rpx;line-height:18rpx;margin-top:6rpx}.kbWarn{background:rgba(255,120,0,.06);border:1rpx solid rgba(255,120,0,.22);border-radius:12rpx;margin-top:10rpx;padding:10rpx 12rpx}.kbSourcesTop{align-items:center;display:flex;gap:10rpx;justify-content:space-between}.kbSources{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:8rpx}