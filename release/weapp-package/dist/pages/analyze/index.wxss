.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:18rpx 16rpx 22rpx;width:100%}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.row{align-items:center;display:flex;gap:12rpx;justify-content:space-between}.headerActions{align-items:center;display:flex;gap:8rpx}.title{font-size:18rpx;font-weight:800;letter-spacing:-.2rpx}.desc{color:rgba(0,0,0,.62);display:block;font-size:13rpx;line-height:18rpx;margin-top:10rpx}.anLoadingRow{align-items:center;background:hsla(0,0%,100%,.55);border:1rpx solid rgba(0,0,0,.06);border-radius:14rpx;display:flex;gap:10rpx;margin-top:12rpx;padding:10rpx 12rpx}.anLoadingText{color:rgba(0,0,0,.56);font-size:12rpx;font-weight:700}.section{margin-top:12rpx}.sectionTitle{font-size:14rpx;font-weight:800}.hint{color:rgba(0,0,0,.55);display:block;font-size:12rpx;margin-top:8rpx}.ovRow{display:flex;gap:12rpx;margin-top:12rpx}.ovItem{background:hsla(0,0%,100%,.55);border:1rpx solid rgba(0,0,0,.06);border-radius:14rpx;flex:1;padding:10rpx}.ovLabel{color:rgba(0,0,0,.55);display:block;font-size:11rpx}.ovValue{display:block;font-size:13rpx;font-weight:800;margin-top:4rpx}.riskList{display:flex;flex-direction:column;gap:10rpx;margin-top:10rpx}.riskItem{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:12rpx}.riskTop{align-items:center;display:flex;gap:10rpx;justify-content:space-between}.riskTitle{font-size:13rpx;font-weight:800}.riskLevel{border:1rpx solid rgba(0,0,0,.12);border-radius:999rpx;font-size:11rpx;padding:2rpx 8rpx}.riskHigh{background:rgba(255,80,80,.09);border-color:rgba(255,80,80,.22);color:rgba(200,0,0,.8)}.riskMid{background:rgba(255,196,0,.11);border-color:rgba(255,196,0,.26);color:rgba(120,70,0,.85)}.riskDesc{color:rgba(0,0,0,.65);display:block;font-size:12rpx;line-height:16rpx;margin-top:6rpx}.cycleList{display:flex;flex-direction:column;gap:10rpx;margin-top:10rpx}.cycleItem{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:12rpx}.cycleTop{align-items:baseline;display:flex;gap:10rpx;justify-content:space-between}.cycleTitle{font-size:13rpx;font-weight:800}.cycleMeta{color:rgba(0,0,0,.58);font-size:12rpx}.cycleTags{display:flex;flex-wrap:wrap;gap:6rpx;margin-top:8rpx}.tag{border:1rpx solid rgba(0,0,0,.12);border-radius:999rpx;font-size:11rpx;padding:3rpx 8rpx}.tagOk{background:rgba(0,160,80,.08);border-color:rgba(0,160,80,.2);color:rgba(0,110,60,.88)}.tagWarn{background:rgba(255,120,0,.1);border-color:rgba(255,120,0,.25);color:rgba(150,60,0,.88)}