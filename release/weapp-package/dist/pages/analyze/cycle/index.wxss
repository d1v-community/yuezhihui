.page{background:#fbfaf8;color:rgba(0,0,0,.92);min-height:100vh}.bg{background:radial-gradient(60% 60% at 15% 25%,hsla(28,24%,72%,.55),hsla(30,28%,90%,0) 55%),radial-gradient(55% 55% at 85% 20%,rgba(139,94,94,.18),hsla(30,28%,90%,0) 60%),radial-gradient(60% 60% at 60% 90%,hsla(28,24%,72%,.32),hsla(30,28%,90%,0) 55%),linear-gradient(180deg,#ede6df,#fff);min-height:100vh}.wrap{margin:0 auto;max-width:560rpx;padding:18rpx 16rpx 22rpx;width:100%}.card{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:16rpx}.row{align-items:center;display:flex;gap:10rpx;justify-content:space-between}.rowRight{display:flex;gap:8rpx}.iconBtn{align-items:center;background:hsla(0,0%,100%,.7);border:1rpx solid rgba(0,0,0,.1);border-radius:12rpx;display:flex;height:34rpx;justify-content:center;width:34rpx}.iconBtnText{color:rgba(0,0,0,.72);font-size:16rpx;line-height:16rpx}.title{font-size:18rpx;font-weight:800;letter-spacing:-.2rpx}.summary{margin-top:10rpx}.summaryTitle{display:block;font-size:14rpx;font-weight:800}.summaryMeta{color:rgba(0,0,0,.6);display:block;font-size:12rpx;margin-top:6rpx}.tags{display:flex;flex-wrap:wrap;gap:6rpx;margin-top:10rpx}.tag{border:1rpx solid rgba(0,0,0,.12);border-radius:999rpx;font-size:11rpx;padding:3rpx 8rpx}.tagOk{background:rgba(0,160,80,.08);border-color:rgba(0,160,80,.2);color:rgba(0,110,60,.88)}.tagWarn{background:rgba(255,120,0,.1);border-color:rgba(255,120,0,.25);color:rgba(150,60,0,.88)}.hint{color:rgba(0,0,0,.55);display:block;font-size:12rpx;margin-top:10rpx}.tagLinks{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:10rpx}.linkChip{background:hsla(0,0%,100%,.6);border:1rpx solid rgba(0,0,0,.12);border-radius:999rpx;padding:6rpx 10rpx}.linkChipText{font-size:12rpx;font-weight:700}.section{margin-top:12rpx}.sectionTitle{font-size:14rpx;font-weight:800}.dayList{display:flex;flex-direction:column;gap:10rpx;margin-top:10rpx}.dayItem{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;padding:12rpx}.dayTop{align-items:baseline;display:flex;gap:10rpx;justify-content:space-between}.dayTitle{font-size:13rpx;font-weight:800}.dayMeta{color:rgba(0,0,0,.58);font-size:12rpx}.dayDesc{color:rgba(0,0,0,.65);display:block;font-size:12rpx;line-height:16rpx;margin-top:6rpx}.settleList{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.92);border:1rpx solid rgba(0,0,0,.08);border-radius:16rpx;margin-top:10rpx;padding:12rpx}.settleItem{color:rgba(0,0,0,.72);display:block;font-size:12rpx;line-height:18rpx}