html{font-size:100rpx!important}input,textarea{font-size:16rpx;line-height:22rpx}button{border-radius:999rpx;font-size:14rpx;line-height:20rpx}button[size="mini"]{border-radius:12rpx;font-size:12rpx;line-height:18rpx}.fc-pressed{filter:brightness(.985);transform:translateZ(0) scale(.985)}@keyframes fc-spin{from{transform:rotate(0deg)}to{transform:rotate(1turn)}}.fc-spinner{animation:fc-spin .8s linear infinite;border:2rpx solid hsla(0,0%,100%,.55);border-radius:999rpx;border-top-color:hsla(0,0%,100%,.95);height:16rpx;width:16rpx}.fc-spinnerDark{border-color:rgba(0,0,0,.55) rgba(0,0,0,.18) rgba(0,0,0,.18)}@keyframes fc-fade-up{from{opacity:0;transform:translate3d(0,10rpx,0)}to{opacity:1;transform:translateZ(0)}}.fc-appear{animation:fc-fade-up .36s cubic-bezier(.2,.8,.2,1) both}